# Supabase (Auth only — never use the service role key in the frontend)
# Project URL from Supabase Dashboard → Settings → API (without /rest/v1)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# .NET API base URL (local, Railway, Render, etc.)
# Example staging: https://platform-api-staging.up.railway.app
VITE_API_URL=http://localhost:5298
